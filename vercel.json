{
    "version": 2,
    "functions": {
        "api/auth/index.js": {
            "runtime": "nodejs20.x"
        },
        "api/stats/index.py": {
            "runtime": "python3.9"
        }
    },
    "rewrites": [
        {
            "source": "/api/stats/(.*)",
            "destination": "/api/stats/index.py"
        },
        {
            "source": "/api/stats",
            "destination": "/api/stats/index.py"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/auth/index.js"
        }
    ]
}